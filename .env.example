# Aegis RAG Configuration
# Copy this to .env and fill in your values

# Gemini API Key (get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Database
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis

# Redis
REDIS_URL=redis://localhost:6379

# OpenSearch
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin123

# S3 Storage (optional - leave empty for local storage)
S3_ENDPOINT_URL=
S3_BUCKET_NAME=aegis-documents
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_SSL=true

# Storage Mode (local or s3)
STORAGE_MODE=local

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Chunking Settings
DEFAULT_CHUNK_SIZE=512
DEFAULT_CHUNK_OVERLAP=50

# Search Settings
DEFAULT_TOP_K=5
BM25_WEIGHT=0.5
RRF_K=60

# LLM Settings
LLM_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
